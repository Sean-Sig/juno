# NOTE: Expo reads .env from each app's directory, not the monorepo root.
# Copy this file to apps/tennis/.env and apps/golf/.env and fill in your values.
# Use your machine's LAN IP (not localhost) so physical devices can reach the server.

# apps/tennis/.env
EXPO_PUBLIC_API_URL=http://<YOUR_LAN_IP>:4000
EXPO_PUBLIC_WS_URL=ws://<YOUR_LAN_IP>:4000/socket
EXPO_PUBLIC_TENNIS_TEAM_ID=00000000-0000-0000-0000-000000000002

# apps/golf/.env
EXPO_PUBLIC_API_URL=http://<YOUR_LAN_IP>:4000
EXPO_PUBLIC_WS_URL=ws://<YOUR_LAN_IP>:4000/socket
EXPO_PUBLIC_GOLF_TEAM_ID=00000000-0000-0000-0000-000000000001
