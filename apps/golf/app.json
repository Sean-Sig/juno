{
  "expo": {
    "name": "Juno Golf",
    "slug": "juno-golf",
    "version": "1.0.0",
    "scheme": "juno-golf",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.juno.golf"
    },
    "android": {
      "package": "com.juno.golf",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#006747"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#006747"
        }
      ]
    ]
  }
}
