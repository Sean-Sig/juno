{
  "name": "juno",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "turbo run start --filter=@juno/main",
    "start:clear": "turbo run start --filter=@juno/main -- --clear",
    "main": "turbo run start --filter=@juno/main",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "packageManager": "npm@11.12.1",
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "~6.0.3"
  }
}
